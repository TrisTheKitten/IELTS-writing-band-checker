# Server-side Gemini API key. Required unless users supply a key in Settings.
# Get one at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Optional. Server fallback when the client sends no model. Defaults to gemini-3.5-flash-lite.
# Allowlisted values: gemini-3.5-flash-lite, gemini-3.6-flash, gemini-3.1-pro
GEMINI_MODEL=gemini-3.5-flash-lite
